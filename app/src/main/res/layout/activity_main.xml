<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_main"
        android:scaleType="centerCrop"
        android:contentDescription="background" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#C0000000" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#DD1A1A1A"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layoutDirection="rtl">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🐍 COBRA CARDS"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvUsername"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤 جاري التحميل..."
                    android:textSize="13sp"
                    android:textColor="#AAAAAA" />
            </LinearLayout>

            <Button
                android:id="@+id/btnLogout"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="خروج"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#880000"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layoutDirection="rtl"
                android:padding="16dp">

                <!-- Balance Card -->
                <TextView
                    android:id="@+id/tvBalance"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💰 رصيدك: ..."
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFD700"
                    android:gravity="center"
                    android:background="#DD1A1A1A"
                    android:padding="16dp"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btnRefresh"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="🔄 تحديث الرصيد"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#333333"
                    android:layout_marginBottom="16dp" />

                <!-- Quick Actions -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <Button
                        android:id="@+id/btnHistory"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="📋 السجل"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#1A3A5C"
                        android:layout_marginEnd="8dp" />

                    <Button
                        android:id="@+id/btnProfile"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="👤 حسابي"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#1A4A2A"
                        android:layout_marginStart="8dp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnAdmin"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="👑 لوحة الأدمن"
                    android:textSize="14sp"
                    android:textColor="#FFD700"
                    android:backgroundTint="#3A2A00"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#444444"
                    android:layout_marginBottom="16dp" />

                <!-- Recharge Section -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚡ شحن فودافون كاش"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:gravity="end"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🎫 اختر الكارت"
                    android:textSize="14sp"
                    android:textColor="#CCCCCC"
                    android:gravity="end"
                    android:layout_marginBottom="6dp" />

                <Spinner
                    android:id="@+id/spinnerProduct"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@android:drawable/btn_dropdown"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📱 رقم المستلم"
                    android:textSize="14sp"
                    android:textColor="#CCCCCC"
                    android:gravity="end"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/etReceiver"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="01XXXXXXXXX"
                    android:inputType="phone"
                    android:textSize="16sp"
                    android:background="@android:drawable/edit_text"
                    android:padding="12dp"
                    android:layout_marginBottom="16dp"
                    android:gravity="center"
                    android:textColor="#000000"
                    android:textColorHint="#888888" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔐 الرقم السري للمحفظة"
                    android:textSize="14sp"
                    android:textColor="#CCCCCC"
                    android:gravity="end"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/etPin"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="6 أرقام"
                    android:inputType="numberPassword"
                    android:textSize="16sp"
                    android:background="@android:drawable/edit_text"
                    android:padding="12dp"
                    android:layout_marginBottom="20dp"
                    android:gravity="center"
                    android:textColor="#000000"
                    android:textColorHint="#888888" />

                <Button
                    android:id="@+id/btnCharge"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:text="⚡ ابدأ الشحن"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#E60000"
                    android:layout_marginBottom="16dp" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="gone"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="15sp"
                    android:gravity="center"
                    android:padding="12dp"
                    android:layout_marginBottom="20dp" />

            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</FrameLayout>
